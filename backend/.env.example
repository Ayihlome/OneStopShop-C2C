# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (Railway Postgres Plugin) ───────────────
# Railway auto-provides DATABASE_URL. If set, the backend uses it directly.
# Otherwise, configure individual vars (Railway template refs shown):
DATABASE_URL=
# ${{Postgres.DATABASE_URL}}    ← Railway auto-generated connection string
# ${{Postgres.PGHOST}}
# ${{Postgres.PGPORT}}
# ${{Postgres.PGDATABASE}}
# ${{Postgres.PGUSER}}
# ${{Postgres.PGPASSWORD}}

# Fallback DB vars (used only when DATABASE_URL is empty):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=onestopshop
DB_USER=postgres
DB_PASSWORD=changeme_strong_password

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────
# Comma-separated list of allowed origins (frontend URLs).
# In Railway, set this to your frontend service URL, e.g.:
# CORS_ORIGINS=https://onestopshop-frontend.up.railway.app
CORS_ORIGINS=http://localhost:5173

# ─── Admin Seed ──────────────────────────────────────
# Used by backend/scripts/seedAdmin.js on first run.
ADMIN_EMAIL=admin@onestopshop.com
ADMIN_PASSWORD=yourchosenpassword

# ─── PayFast (Sandbox) ──────────────────────────────
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_RETURN_URL=http://localhost:5173/booking/success
PAYFAST_CANCEL_URL=http://localhost:5173/booking/cancel
PAYFAST_NOTIFY_URL=http://localhost:3000/api/payments/itn
