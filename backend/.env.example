# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (Railway Postgres Plugin) ───────────────
# Railway auto-provides DATABASE_URL. If set, the backend uses it directly.
# No need to set individual DB_* vars when DATABASE_URL is present.
DATABASE_URL=

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────
# REQUIRED IN PRODUCTION: Comma-separated list of allowed origins.
# Set this to your frontend's Railway URL, e.g.:
#   CORS_ORIGINS=https://onestopshop-frontend.up.railway.app
# Local dev defaults (localhost:5173) are hardcoded — you only need to set
# this for Railway/full URLs.
CORS_ORIGINS=

# ─── Admin Seed ──────────────────────────────────────
# Used by scripts/seedAdmin.js on first deploy.
ADMIN_EMAIL=admin@onestopshop.com
ADMIN_PASSWORD=yourchosenpassword

# ─── PayFast (Sandbox) ──────────────────────────────
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_RETURN_URL=http://localhost:5173/booking/success
PAYFAST_CANCEL_URL=http://localhost:5173/booking/cancel
PAYFAST_NOTIFY_URL=http://localhost:3000/api/payments/itn

# ─── WhatsApp Cloud API ──────────────────────────
# Get these from your Meta Business account:
# https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
