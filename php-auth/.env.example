# Database connection string (PostgreSQL)
# Format: pgsql:host=hostname;port=5432;dbname=dbname;user=user;password=pass
# Or use full URL: postgresql://user:***@hostname:5432/dbname
DATABASE_URL="pgsql:host=localhost;port=5432;dbname=onestopshop;user=postgres;password=postgres"

# Backend URL — used to download uploaded files on separate-container deployments
# Set this to the Railway backend service URL, e.g. https://backend.up.railway.app
# Falls back to http://localhost:3000 for local development
# BACKEND_URL="https://backend.up.railway.app"
